{
  "name": "codeux",
  "version": "1.0.0",
  "description": "Containerized environment for running and managing AI sub-agents",
  "author": "Pierre Voss <p.voss@codeux.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeux-ai/codeux.git"
  },
  "bugs": {
    "url": "https://github.com/codeux-ai/codeux/issues"
  },
  "homepage": "https://github.com/codeux-ai/codeux#readme",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeux": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo && vite build",
    "start": "node scripts/supervisor.mjs dist/index.js",
    "start:raw": "node dist/index.js",
    "dev": "node scripts/supervisor.mjs --import ./scripts/tsnode-register.mjs src/index.ts",
    "dev:raw": "node --import ./scripts/tsnode-register.mjs src/index.ts",
    "electron:generate-icons": "node scripts/generate-electron-icons.mjs",
    "electron:prepare-deps": "node scripts/prepare-electron-runtime-deps.mjs && pnpm run electron:generate-icons",
    "electron:dev": "pnpm run build && electron dist/electron/main.js",
    "electron:pack": "pnpm run build && pnpm run electron:prepare-deps && electron-builder --config electron-builder.config.cjs --dir",
    "electron:dist": "pnpm run build && pnpm run electron:prepare-deps && electron-builder --config electron-builder.config.cjs",
    "electron:dist:linux": "pnpm run build && pnpm run electron:prepare-deps && electron-builder --config electron-builder.config.cjs --linux",
    "electron:dist:mac": "pnpm run build && pnpm run electron:prepare-deps && electron-builder --config electron-builder.config.cjs --mac",
    "electron:dist:win": "pnpm run build && pnpm run electron:prepare-deps && electron-builder --config electron-builder.config.cjs --win",
    "electron:benchmark:runtime": "node scripts/benchmark-electron-runtime.mjs",
    "electron:benchmark:win": "node scripts/benchmark-electron-windows.mjs",
    "electron:install-deps": "electron-builder install-app-deps",
    "test": "vitest run",
    "smoketest:codex": "node --import ./scripts/tsnode-register.mjs tests/smoketest/codex.smoketest.ts",
    "test:backend": "vitest run tests/backend",
    "test:dashboard": "vitest run tests/dashboard",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend:coverage": "vitest run tests/backend --coverage",
    "lint": "tsc --noEmit --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo",
    "ci": "pnpm run lint && pnpm run test:backend:coverage && pnpm run test:dashboard && pnpm run build",
    "audit": "pnpm audit --audit-level=high",
    "smoke-test": "node dist/index.js --help",
    "build:server": "tsc",
    "build:dashboard": "tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo && vite build",
    "dev:dashboard": "vite",
    "typecheck:dashboard": "tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "axios": "^1.16.0",
    "colord": "^2.9.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "js-tiktoken": "^1.0.21",
    "onnxruntime-node": "^1.24.3",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "1.166.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "gsap": "^3.14.2",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "lucide-preact": "^0.577.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.3",
    "monaco-editor": "^0.55.1",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "react-arborist": "^3.8.0",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.35"
  }
}
