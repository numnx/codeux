{
  "name": "jules-subagents",
  "version": "1.2.0",
  "description": "Model Context Protocol server for the Jules Agent API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jules-subagents": "dist/index.js",
    "sprint-os-worker": "dist/worker/index.js"
  },
  "scripts": {
    "build": "tsc && tsc -p dashboard/tsconfig.json --noEmit && vite build",
    "start": "node dist/index.js",
    "dev": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' src/index.ts",
    "test": "vitest run",
    "test:backend": "vitest run tests/backend",
    "test:dashboard": "vitest run tests/dashboard",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend:coverage": "vitest run tests/backend --coverage",
    "lint": "echo 'linting...' && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm test",
    "smoke-test": "node dist/index.js --help",
    "build:server": "tsc",
    "build:dashboard": "tsc -p dashboard/tsconfig.json --noEmit && vite build",
    "dev:dashboard": "vite",
    "typecheck:dashboard": "tsc -p dashboard/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-router": "1.166.2",
    "ajv": "^8.18.0",
    "axios": "^1.13.5",
    "colord": "^2.9.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "js-tiktoken": "^1.0.21",
    "lucide-preact": "^0.577.0",
    "marked": "^17.0.3",
    "onnxruntime-node": "^1.24.3",
    "preact": "^10.29.0",
    "three": "^0.183.2"
  },
  "overrides": {
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
