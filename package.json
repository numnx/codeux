{
  "name": "jules-subagents",
  "version": "1.2.0",
  "description": "Model Context Protocol server for the Jules Agent API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jules-subagents": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc -p dashboard/tsconfig.json --noEmit && vite build",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'linting...' && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm test",
    "smoke-test": "node dist/index.js --help",
    "build:server": "tsc",
    "build:dashboard": "tsc -p dashboard/tsconfig.json --noEmit && vite build",
    "dev:dashboard": "vite",
    "typecheck:dashboard": "tsc -p dashboard/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-router": "^1.166.2",
    "ajv": "^8.18.0",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "lucide-preact": "^0.577.0",
    "marked": "^17.0.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
