{
  "name": "jules-subagents",
  "version": "1.2.0",
  "description": "Model Context Protocol server for the Jules Agent API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jules-subagents": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:dashboard",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "tsc",
    "build:dashboard": "npm run typecheck:dashboard && vite build",
    "dev:dashboard": "vite",
    "typecheck:dashboard": "tsc -p dashboard/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "marked": "^17.0.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
