{
  "name": "jules-subagents",
  "version": "1.2.0",
  "description": "Model Context Protocol server for the Jules Agent API.",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jules-subagents": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo && tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo && vite build",
    "start": "node dist/index.js",
    "dev": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' src/index.ts",
    "test": "vitest run",
    "test:backend": "vitest run tests/backend",
    "test:dashboard": "vitest run tests/dashboard",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend:coverage": "vitest run tests/backend --coverage",
    "lint": "tsc --noEmit --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo",
    "ci": "pnpm run lint && pnpm run test:backend:coverage && pnpm run test:dashboard && pnpm run build",
    "audit": "pnpm audit --audit-level=high",
    "smoke-test": "node dist/index.js --help",
    "build:server": "tsc --incremental --tsBuildInfoFile .cache/tsc/root.tsbuildinfo",
    "build:dashboard": "tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo && vite build",
    "dev:dashboard": "vite",
    "typecheck:dashboard": "tsc -p dashboard/tsconfig.json --noEmit --incremental --tsBuildInfoFile .cache/tsc/dashboard.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@preact/signals": "^2.9.0",
    "@tanstack/react-router": "1.166.2",
    "ajv": "^8.18.0",
    "axios": "^1.16.0",
    "colord": "^2.9.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "js-tiktoken": "^1.0.21",
    "lucide-preact": "^0.577.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.3",
    "onnxruntime-node": "^1.24.3",
    "p-limit": "^7.3.0",
    "preact": "^10.29.0",
    "three": "^0.183.2"
  },
  "pnpm": {
    "overrides": {
      "express-rate-limit": "^8.3.2",
      "hono": "^4.12.7",
      "path-to-regexp": "^8.4.2",
      "@rollup/pluginutils@4.2.1>picomatch": "2.3.2",
      "@rollup/pluginutils@5.3.0>picomatch": "4.0.4"
    }
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
